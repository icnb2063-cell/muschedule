{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "muschedule",
  "main": "src/worker.js",
  "compatibility_date": "2026-07-03",
  "assets": {
    "directory": "./public",
    "binding": "ASSETS"
  },
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "muscheddb",
      "database_id": "e2d0edbd-ba88-4684-a0e1-88ab49ffd135"
    }
  ]
}
